<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="br.com.model.Projeto" table="Projeto">        
        
        <id name="id" column="id">            
            <generator class="sequence">                
                <param name="sequence">id_proj</param>
            </generator>
        </id>
        
        <property name="titulo" column="TITULO" not-null="true"/>
        <property name="palavrasChave" column="palavras_chave" not-null="true"/>
        <property name="resumo" column="RESUMO" not-null="true"/>
        <property name="tipoProjeto" column="TIPO_PROJETO" not-null="true"/>
        <property name="participantes" column="" not-null="true"/>
        <property name="" column="" not-null="true"/>
        <property name="" column="" not-null="true"/>
        <property name="" column="" not-null="true"/>
        <property name="" column="" not-null="true"/>
        <property name="" column="" not-null="true"/>                                                        
            
    </class>
</hibernate-mapping>
